{
    "name": "dmkravchuk/ip-clock",
    "description": "Resolves accurate server time and timezone via external IP lookup",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Dmytro Kravchuk",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "psr/clock": "^1.0",
        "psr/log": "^3.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "DmKravchuk\\IpClock\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DmKravchuk\\IpClock\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite Unit",
        "test:feature": "phpunit --testsuite Feature",
        "test:integration": "phpunit --testsuite Integration",
        "analyse": "phpstan analyse src tests --level=8"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
